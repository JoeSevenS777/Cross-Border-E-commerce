@dataclass
class PageInfo:
    index: int
    raw_text: str
    normalized_text: str
    kind: str  # logistics / pick / empty


@dataclass
class PdfInfo:
    original_path: Path
    logistics_key: str
    target_name: str
    logistics_count: int
    logistics_page_indices: list[int]
    renamed_original_path: Path | None = None
    no_pick_path: Path | None = None


class ProcessingError(Exception):
    pass


def main() -> None:
    try:
        winrar_exe = find_winrar_exe()
        pdf_paths = get_pdf_files(SCRIPT_DIR)
        pdf_infos = [analyze_pdf(path) for path in pdf_paths]

        assign_output_names(pdf_infos)
        rename_original_pdfs(pdf_infos)
        build_no_pick_pdfs(pdf_infos)

        all_outputs = collect_output_files(pdf_infos)
        total_logistics_count = sum(info.logistics_count for info in pdf_infos)
        rar_path = build_output_rar_path(OUTPUT_DIR, total_logistics_count)
        create_rar(winrar_exe, rar_path, all_outputs)
        delete_files(all_outputs)

        print("Done.")
        print(f"RAR created: {rar_path}")

    except ProcessingError as exc:
        print(f"ERROR: {exc}")
        sys.exit(1)
    except Exception as exc:
        print(f"UNEXPECTED ERROR: {exc}")
        sys.exit(1)


def get_pdf_files(folder: Path) -> list[Path]:
    pdfs = sorted(
        p for p in folder.iterdir() if p.is_file() and p.suffix.lower() in ALLOWED_SUFFIXES
    )
    if not pdfs:
        raise ProcessingError(f"No PDF files found in: {folder}")
    return pdfs


def analyze_pdf(path: Path) -> PdfInfo:
    page_texts = read_pdf_texts(path)
    if not page_texts:
        raise ProcessingError(f"PDF has no pages: {path.name}")

    full_text = "\n".join(page_texts)
    logistics_key = detect_logistics_type(path.name, full_text)
    target_name = LOGISTICS_RULES[logistics_key]["target_name"]

    page_infos = classify_pages(page_texts, logistics_key)
    logistics_page_indices = [page.index for page in page_infos if page.kind == "logistics"]

    if not logistics_page_indices:
        raise ProcessingError(f"No logistics label pages detected in: {path.name}")

    return PdfInfo(
        original_path=path,
        logistics_key=logistics_key,
        target_name=target_name,
        logistics_count=len(logistics_page_indices),
        logistics_page_indices=logistics_page_indices,
    )


def read_pdf_texts(path: Path) -> list[str]:
    try:
        reader = PdfReader(str(path))
    except Exception as exc:
        raise ProcessingError(f"Failed to read PDF: {path.name}. Details: {exc}") from exc

    page_texts: list[str] = []
    for idx, page in enumerate(reader.pages, start=1):
        try:
            text = page.extract_text() or ""
        except Exception as exc:
            raise ProcessingError(
                f"Failed to extract text from {path.name}, page {idx}. Details: {exc}"
            ) from exc
        page_texts.append(text)
    return page_texts


def normalize_text(text: str) -> str:
    text = text.replace("\u3000", " ")
    text = text.replace("\r", "\n")
    text = re.sub(r"[ \t]+", " ", text)
    return text


def compact(text: str) -> str:
    return re.sub(r"\s+", "", text).lower()


def fuzzy_contains(text: str, keyword: str) -> bool:
    return compact(keyword) in compact(text)


def detect_logistics_type(filename: str, full_text: str) -> str:
    matched: list[str] = []
    for logistics_key, rule in LOGISTICS_RULES.items():
        if any(fuzzy_contains(full_text, keyword) for keyword in rule["keywords"]):
            matched.append(logistics_key)

    if len(matched) == 1:
        return matched[0]

    if not matched:
        raise ProcessingError(
            f"Unrecognized logistics type in file: {filename}. Only these types are allowed: "
            f"統一超商 / 標準配送 / FamilyMart / 隔日到貨 / Hi-Life"
        )

    # Prefer more specific types when overlaps happen.
    if "next_day" in matched and "store_to_store" in matched:
        matched = [m for m in matched if m != "store_to_store"]
    if len(matched) == 1:
        return matched[0]

    raise ProcessingError(f"Ambiguous logistics type in file: {filename}. Matched types: {matched}")


def classify_pages(page_texts: list[str], logistics_key: str) -> list[PageInfo]:
    result: list[PageInfo] = []
    strong_markers = LOGISTICS_RULES[logistics_key]["strong_page_markers"]

    previous_kind = "start"
    for idx, raw_text in enumerate(page_texts):
        normalized = normalize_text(raw_text)
        kind = classify_single_page(normalized, strong_markers, previous_kind)
        result.append(PageInfo(index=idx, raw_text=raw_text, normalized_text=normalized, kind=kind))
        previous_kind = kind

    return result


def classify_single_page(text: str, strong_logistics_markers: list[str], previous_kind: str) -> str:
    stripped = compact(text)
    if not stripped or len(stripped) <= 6:
        return "empty"

    pick_hits = sum(1 for marker in PICK_PAGE_MARKERS if fuzzy_contains(text, marker))
    logistics_hits = sum(1 for marker in strong_logistics_markers if fuzzy_contains(text, marker))
    continuation_rows = count_pick_continuation_rows(text)

    # Strong logistics anchor page.
    if logistics_hits >= 2:
        return "logistics"

    # Strong pick-label header page.
    if pick_hits >= 3:
        return "pick"

    # Pick table continuation page: often a second page of item rows with no header.
    if continuation_rows >= 2 and logistics_hits == 0:
        return "pick_continuation"

    # Context-aware continuation: if a pick page spills over, the next page may contain
    # only shelf rows and quantities without the usual Order/Tracking header markers.
    if previous_kind in {"pick", "pick_continuation"} and continuation_rows >= 1 and logistics_hits == 0:
        return "pick_continuation"

    # If the page looks like warehouse picking output, treat it as pick.
    if pick_hits >= 2 and ("zz" in stripped or "orderno:" in stripped or "trackingno:" in stripped):
        return "pick"

    # Empty / nearly blank pages are ignored.
    if len(re.sub(r"[^A-Za-z0-9一-鿿]", "", text)) <= 4:
        return "empty"

    # Conservative fallback: only treat a page as logistics if it still shows at least one
    # carrier-specific marker and does not look like pick-label continuation content.
    if logistics_hits >= 1 and continuation_rows == 0:
        return "logistics"

    # Unknown pages are treated as non-logistics so they never inflate the label count.
    return "unknown"

    # If the page looks like warehouse picking output, treat it as pick.
    if pick_hits >= 2 and ("zz" in stripped or "orderno:" in stripped or "trackingno:" in stripped):
        return "pick"

    # Empty / nearly blank pages are ignored.
    if len(re.sub(r"[^A-Za-z0-9\u4e00-\u9fff]", "", text)) <= 4:
        return "empty"

    # Fallback by subtraction philosophy: pages that are not clearly pick or empty
    # are treated as logistics pages.
    return "logistics"


def count_pick_continuation_rows(text: str) -> int:
    row_count = 0
    for line in text.splitlines():
        clean = line.strip()
        if not clean:
            continue
        if re.match(r"^[A-Z][0-9]{1,2}-[0-9]{2}-[0-9]{2}", clean):
            row_count += 1
            continue
        if re.match(r"^[A-Z][0-9]-[0-9]-[0-9]", clean):
            row_count += 1
            continue
    return row_count


def assign_output_names(pdf_infos: list[PdfInfo]) -> None:
    groups: dict[str, list[PdfInfo]] = {}
    for info in pdf_infos:
        groups.setdefault(info.target_name, []).append(info)

    reserved: set[str] = set()

    for target_name, items in groups.items():
        items.sort(key=lambda item: item.original_path.name.lower())
        for index, info in enumerate(items, start=1):
            base_name = f"{target_name}-{info.logistics_count}单"
            if len(items) > 1:
                base_name = f"{base_name}({index})"

            original_filename = make_unique_filename(base_name, ".pdf", reserved)
            no_pick_filename = make_unique_filename(f"{base_name}{NO_PICK_SUFFIX}", ".pdf", reserved)

            info.renamed_original_path = info.original_path.with_name(original_filename)
            info.no_pick_path = info.original_path.with_name(no_pick_filename)

            reserved.add(original_filename.lower())
            reserved.add(no_pick_filename.lower())


def make_unique_filename(stem: str, suffix: str, reserved: set[str]) -> str:
    candidate = f"{stem}{suffix}"
    counter = 2
    while candidate.lower() in reserved:
        candidate = f"{stem}({counter}){suffix}"
        counter += 1
    return candidate


def rename_original_pdfs(pdf_infos: list[PdfInfo]) -> None:
    for info in pdf_infos:
        if info.renamed_original_path is None:
            raise ProcessingError(f"Internal error: no renamed output path for {info.original_path.name}")
        if info.no_pick_path is None:
            raise ProcessingError(f"Internal error: no no-pick output path for {info.original_path.name}")
        if info.no_pick_path.exists():
            raise ProcessingError(f"Target file already exists: {info.no_pick_path.name}")
        if info.renamed_original_path.exists() and info.renamed_original_path.resolve() != info.original_path.resolve():
            raise ProcessingError(f"Target file already exists: {info.renamed_original_path.name}")

    for info in pdf_infos:
        assert info.renamed_original_path is not None
        if info.original_path.resolve() == info.renamed_original_path.resolve():
            continue
        try:
            info.original_path.rename(info.renamed_original_path)
        except Exception as exc:
            raise ProcessingError(
                f"Failed to rename {info.original_path.name} -> {info.renamed_original_path.name}. Details: {exc}"
            ) from exc


def build_no_pick_pdfs(pdf_infos: list[PdfInfo]) -> None:
    for info in pdf_infos:
        assert info.renamed_original_path is not None
        assert info.no_pick_path is not None

        try:
            reader = PdfReader(str(info.renamed_original_path))
        except Exception as exc:
            raise ProcessingError(f"Failed to reopen renamed PDF: {info.renamed_original_path.name}. Details: {exc}") from exc

        writer = PdfWriter()
        for page_index in info.logistics_page_indices:
            try:
                writer.add_page(reader.pages[page_index])
            except Exception as exc:
                raise ProcessingError(
                    f"Failed to copy logistics page {page_index + 1} from {info.renamed_original_path.name}. Details: {exc}"
                ) from exc

        if len(writer.pages) != info.logistics_count:
            raise ProcessingError(
                f"No-pick PDF page count mismatch in {info.renamed_original_path.name}. "
                f"Expected: {info.logistics_count}, actual: {len(writer.pages)}"
            )

        try:
            with open(info.no_pick_path, "wb") as f:
                writer.write(f)
        except Exception as exc:
            raise ProcessingError(
                f"Failed to write no-pick PDF: {info.no_pick_path.name}. Details: {exc}"
            ) from exc


def collect_output_files(pdf_infos: list[PdfInfo]) -> list[Path]:
    files: list[Path] = []
    for info in pdf_infos:
        assert info.renamed_original_path is not None
        assert info.no_pick_path is not None
        files.append(info.renamed_original_path)
        files.append(info.no_pick_path)
    return files


def find_winrar_exe() -> Path:
    candidates = [
        Path(r"C:\Program Files\WinRAR\WinRAR.exe"),
        Path(r"C:\Program Files (x86)\WinRAR\WinRAR.exe"),
        Path(r"C:\Program Files\WinRAR\Rar.exe"),
        Path(r"C:\Program Files (x86)\WinRAR\Rar.exe"),
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate

    winrar_from_path = shutil.which("WinRAR") or shutil.which("Rar") or shutil.which("rar")
    if winrar_from_path:
        return Path(winrar_from_path)

    raise ProcessingError("WinRAR was not found. WinRAR must be installed and callable, otherwise the script stops.")


def build_output_rar_path(output_dir: Path, total_count: int) -> Path:
    output_dir.mkdir(parents=True, exist_ok=True)

    date_prefix = datetime.today().strftime("%Y%m%d")
    family_prefix = f"{date_prefix}{RAR_BASE_NAME}-"

    existing_same_day_archives: list[Path] = []
    for candidate in output_dir.iterdir():
        if not candidate.is_file():
            continue
        if candidate.suffix.lower() != ".rar":
            continue
        if candidate.name.startswith(family_prefix):
            existing_same_day_archives.append(candidate)

    batch_number = len(existing_same_day_archives) + 1
    base_stem = f"{date_prefix}{RAR_BASE_NAME}-{total_count}单"

    if batch_number == 1:
        candidate = output_dir / f"{base_stem}.rar"
        if not candidate.exists():
            return candidate
        batch_number = 2

    batch_suffix = to_chinese_batch_suffix(batch_number)
    candidate = output_dir / f"{base_stem}{batch_suffix}.rar"

    if not candidate.exists():
        return candidate

    while True:
        batch_number += 1
        batch_suffix = to_chinese_batch_suffix(batch_number)
        candidate = output_dir / f"{base_stem}{batch_suffix}.rar"
        if not candidate.exists():
            return candidate


def to_chinese_batch_suffix(batch_number: int) -> str:
    if batch_number <= 1:
        return ""

    numerals = {
        2: "二",
        3: "三",
        4: "四",
        5: "五",
        6: "六",
        7: "七",
        8: "八",
        9: "九",
        10: "十",
    }

    if batch_number in numerals:
        return f"（第{numerals[batch_number]}批）"

    if 11 <= batch_number <= 19:
        ones = batch_number - 10
        one_part = numerals[ones] if ones > 0 else ""
        return f"（第十{one_part}批）"

    tens = batch_number // 10
    ones = batch_number % 10
    tens_part = numerals.get(tens, str(tens))
    ones_part = numerals.get(ones, "") if ones else ""
    return f"（第{tens_part}十{ones_part}批）"


def create_rar(winrar_exe: Path, rar_path: Path, files: list[Path]) -> None:
    if not files:
        raise ProcessingError("No output files are available for compression.")

    cmd = [
        str(winrar_exe),
        "a",
        "-ep",
        str(rar_path),
        *[str(p) for p in files],
    ]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
    except Exception as exc:
        raise ProcessingError(f"Failed to launch WinRAR. Details: {exc}") from exc

    if result.returncode != 0:
        raise ProcessingError(
            "WinRAR failed to create the RAR archive.\n"
            f"Return code: {result.returncode}\n"
            f"STDOUT: {result.stdout.strip()}\n"
            f"STDERR: {result.stderr.strip()}"
        )

    if not rar_path.exists() or rar_path.stat().st_size == 0:
        raise ProcessingError("RAR creation appeared to succeed, but the output RAR file was not created correctly.")


def delete_files(files: list[Path]) -> None:
    for file_path in files:
        try:
            file_path.unlink()
        except Exception as exc:
            raise ProcessingError(
                f"RAR was created, but failed to delete source file: {file_path.name}. Details: {exc}"
            ) from exc


if __name__ == "__main__":
    main()
