Option Explicit

Private Function LabelText_Shelf() As String
LabelText_Shelf = ChrW(&H8CA8) & ChrW(&H67B6) & ChrW(&H4F4D) & ":"
End Function

Private Function LabelText_SKU() As String
LabelText_SKU = "SKU:"
End Function

Private Function LabelText_GTIN() As String
LabelText_GTIN = "GTIN:"
End Function

Private Function LabelText_Qty() As String
LabelText_Qty = ChrW(&H6578) & ChrW(&H91CF) & ":"
End Function

Private Sub ApplyCJKFont(ByVal ws As Worksheet)
On Error Resume Next
ws.Cells.Font.Name = "Microsoft JhengHei"
If Err.Number <> 0 Then
Err.Clear
ws.Cells.Font.Name = "Microsoft YaHei UI"
End If
If Err.Number <> 0 Then
Err.Clear
ws.Cells.Font.Name = "PMingLiU"
End If
If Err.Number <> 0 Then
Err.Clear
ws.Cells.Font.Name = "SimSun"
End If
On Error GoTo 0
End Sub

Private Function GetHeaderColumn(ByVal ws As Worksheet, ByVal headerText As String, Optional ByVal headerRow As Long = 1) As Long
Dim lastCol As Long
Dim colNum As Long
Dim cellValue As String


lastCol = ws.Cells(headerRow, ws.Columns.Count).End(xlToLeft).Column

For colNum = 1 To lastCol
    cellValue = Trim(CStr(ws.Cells(headerRow, colNum).Value))
    If StrComp(cellValue, headerText, vbTextCompare) = 0 Then
        GetHeaderColumn = colNum
        Exit Function
    End If
Next colNum

GetHeaderColumn = 0


End Function

Private Function IsPrintedStatus(ByVal statusText As String) As Boolean
IsPrintedStatus = (InStr(1, Trim$(statusText), "已打印", vbTextCompare) > 0)
End Function

Public Sub PrintSelectedLabelsPreview()
Dim wb As Workbook
Dim wsData As Worksheet
Dim wsLabel As Worksheet
Dim selectedRows As Collection
Dim area As Range
Dim cell As Range
Dim rowNum As Long
Dim i As Long
Dim pageCount As Long
Dim topRow As Long
Dim bottomRow As Long
Dim pageBreakRow As Long
Dim lastDataRow As Long
Dim headerRow As Long

Dim colSKU As Long
Dim colGTIN As Long
Dim colShelf As Long
Dim colQty As Long
Dim colPrintStatus As Long

Dim statusText As String
Dim warnResult As VbMsgBoxResult
Dim confirmResult As VbMsgBoxResult
Dim printStamp As String
Dim printedRows As String

Set wb = ThisWorkbook
Set wsData = wb.Worksheets("Sheet1")
Set wsLabel = wb.Worksheets("PrintPreview")
headerRow = 1

colSKU = GetHeaderColumn(wsData, "SKU编号", headerRow)
colGTIN = GetHeaderColumn(wsData, "GTIN", headerRow)
colShelf = GetHeaderColumn(wsData, "台湾货架位", headerRow)
colQty = GetHeaderColumn(wsData, "调拨数量", headerRow)
colPrintStatus = GetHeaderColumn(wsData, "标签打印状态", headerRow)

If colSKU = 0 Or colGTIN = 0 Or colShelf = 0 Or colQty = 0 Or colPrintStatus = 0 Then
    MsgBox "Required headers were not found on Sheet1. Please check: SKU编号, GTIN, 台湾货架位, 调拨数量, 打印状态", vbCritical
    Exit Sub
End If

If ActiveSheet.Name <> wsData.Name Then
    MsgBox "Please go to Sheet1, select the SKU cells or rows you want, and run the macro again.", vbExclamation
    Exit Sub
End If

If TypeName(Selection) <> "Range" Then
    MsgBox "Please select the SKU cells or rows you want to preview.", vbExclamation
    Exit Sub
End If

Set selectedRows = New Collection
lastDataRow = wsData.Cells(wsData.Rows.Count, colSKU).End(xlUp).Row

On Error Resume Next
For Each area In Selection.Areas
    For Each cell In area.Cells
        rowNum = cell.Row
        If rowNum > headerRow And rowNum <= lastDataRow Then
            If Len(Trim(CStr(wsData.Cells(rowNum, colSKU).Value))) > 0 Then
                selectedRows.Add rowNum, CStr(rowNum)
            End If
        End If
    Next cell
Next area
On Error GoTo 0

If selectedRows.Count = 0 Then
    MsgBox "No valid SKU rows were found in your selection.", vbExclamation
    Exit Sub
End If

printedRows = ""
For i = 1 To selectedRows.Count
    rowNum = CLng(selectedRows(i))
    statusText = CStr(wsData.Cells(rowNum, colPrintStatus).Value)
    If IsPrintedStatus(statusText) Then
        If printedRows = "" Then
            printedRows = CStr(rowNum)
        Else
            printedRows = printedRows & "," & rowNum
        End If
    End If
Next i

If printedRows <> "" Then
    warnResult = MsgBox("行 " & printedRows & " 已打印，请确认是否继续打印？", vbYesNo + vbExclamation, "重复打印确认")
    If warnResult = vbNo Then
        Exit Sub
    End If
End If

Application.ScreenUpdating = False

wsLabel.Cells.Clear
wsLabel.ResetAllPageBreaks

With wsLabel.PageSetup
    .Zoom = False
    .FitToPagesWide = 1
    .FitToPagesTall = False
    .Orientation = xlPortrait
    .CenterHorizontally = True
    .CenterVertically = True
    .LeftMargin = Application.CentimetersToPoints(0.5)
    .RightMargin = Application.CentimetersToPoints(0.5)
    .TopMargin = Application.CentimetersToPoints(0.5)
    .BottomMargin = Application.CentimetersToPoints(0.5)
    .HeaderMargin = 0
    .FooterMargin = 0
End With

wsLabel.Columns("A").ColumnWidth = 10
wsLabel.Columns("B").ColumnWidth = 32

pageCount = selectedRows.Count

For i = 1 To pageCount
    topRow = (i - 1) * 8 + 1
    bottomRow = topRow + 3

    wsLabel.Range("A" & topRow).Value = LabelText_Shelf()
    wsLabel.Range("A" & (topRow + 1)).Value = LabelText_SKU()
    wsLabel.Range("A" & (topRow + 2)).Value = LabelText_GTIN()
    wsLabel.Range("A" & (topRow + 3)).Value = LabelText_Qty()

    wsLabel.Range("B" & topRow).Value = wsData.Cells(selectedRows(i), colShelf).Value
    wsLabel.Range("B" & (topRow + 1)).Value = wsData.Cells(selectedRows(i), colSKU).Value
    wsLabel.Range("B" & (topRow + 2)).NumberFormat = "@"
    wsLabel.Range("B" & (topRow + 2)).Value = CStr(wsData.Cells(selectedRows(i), colGTIN).Value)
    wsLabel.Range("B" & (topRow + 3)).Value = wsData.Cells(selectedRows(i), colQty).Value

    With wsLabel.Range("A" & topRow & ":B" & bottomRow)
        .Borders.LineStyle = xlContinuous
        .Borders.Weight = xlThin
        .VerticalAlignment = xlCenter
        .HorizontalAlignment = xlLeft
        .WrapText = True
    End With

    wsLabel.Rows(topRow).RowHeight = 36
    wsLabel.Rows(topRow + 1).RowHeight = 52
    wsLabel.Rows(topRow + 2).RowHeight = 36
    wsLabel.Rows(topRow + 3).RowHeight = 36

    With wsLabel.Range("A" & topRow & ":A" & bottomRow)
        .Font.Bold = True
        .Font.Size = 16
    End With

    With wsLabel.Range("B" & topRow & ":B" & bottomRow)
        .Font.Size = 16
    End With

    wsLabel.Range("B" & (topRow + 1)).Font.Size = 14

    If i < pageCount Then
        pageBreakRow = topRow + 8
        wsLabel.HPageBreaks.Add Before:=wsLabel.Rows(pageBreakRow)
    End If
Next i

ApplyCJKFont wsLabel

wsLabel.PageSetup.PrintArea = wsLabel.Range("A1:B" & ((pageCount - 1) * 8 + 4)).Address

Application.ScreenUpdating = True

wsLabel.PrintPreview

confirmResult = MsgBox("请确认：以上标签是否已经成功打印？" & vbCrLf & "点击“是”将标记为“已打印”。", vbYesNo + vbQuestion, "打印确认")

If confirmResult = vbYes Then
    printStamp = Format(Now, "mm/dd_hh:mm") & "已打印"
    For i = 1 To selectedRows.Count
        rowNum = CLng(selectedRows(i))
        wsData.Cells(rowNum, colPrintStatus).Value = printStamp
    Next i
End If

End Sub

