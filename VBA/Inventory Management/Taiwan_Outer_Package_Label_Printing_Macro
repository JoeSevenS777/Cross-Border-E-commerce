Option Explicit

Private Function BoxLabel_Text_Title() As String
    BoxLabel_Text_Title = ChrW(&H7F8E) & ChrW(&H599D) & ChrW(&H88DC) & ChrW(&H8CA8)
End Function

Private Function BoxLabel_Text_BoxNo() As String
    BoxLabel_Text_BoxNo = ChrW(&H7BB1) & ChrW(&H865F) & ":"
End Function

Private Function BoxLabel_Text_SKUCount() As String
    BoxLabel_Text_SKUCount = "SKU" & ChrW(&H7E3D) & ChrW(&H6578) & ChrW(&HFF1A)
End Function

Private Function BoxLabel_Text_TotalQty() As String
    BoxLabel_Text_TotalQty = ChrW(&H7E3D) & ChrW(&H6578) & ChrW(&H91CF) & ChrW(&HFF1A)
End Function

Private Function BoxLabel_Text_DetailHeader_Left() As String
    BoxLabel_Text_DetailHeader_Left = ChrW(&H660E) & ChrW(&H7D30) & "SKU " & ChrW(&H2193)
End Function

Private Function BoxLabel_Text_QtyHeader() As String
    BoxLabel_Text_QtyHeader = ChrW(&H6578) & ChrW(&H91CF) & ChrW(&H2193)
End Function

Private Function BoxLabel_Text_DetailHeader_Right() As String
    BoxLabel_Text_DetailHeader_Right = ChrW(&H8CA8) & ChrW(&H67B6) & ChrW(&H4F4D) & ChrW(&H2193)
End Function

Private Function BoxLabel_Text_PageInfo(ByVal currentPage As Long, ByVal totalPages As Long) As String
    BoxLabel_Text_PageInfo = ChrW(&H7B2C) & currentPage & ChrW(&H9801) & "/" & ChrW(&H5171) & totalPages & ChrW(&H9801)
End Function

Private Function NormalizeBoxNo(ByVal v As Variant) As String
    Dim s As String

    s = Trim$(CStr(v))
    If s = "" Then
        NormalizeBoxNo = ""
        Exit Function
    End If

    If IsNumeric(s) Then
        If CDbl(s) <> Int(CDbl(s)) Then
            NormalizeBoxNo = s
        Else
            NormalizeBoxNo = Format$(CLng(Val(s)), "00")
        End If
    Else
        NormalizeBoxNo = s
    End If
End Function

Private Sub AddUniqueBox(ByRef col As Collection, ByVal boxNo As String)
    On Error Resume Next
    col.Add boxNo, boxNo
    On Error GoTo 0
End Sub

Private Function NormalizeHeaderText(ByVal v As Variant) As String
    Dim s As String

    s = CStr(v)
    s = Replace(s, " ", "")
    s = Replace(s, vbCr, "")
    s = Replace(s, vbLf, "")
    s = Replace(s, ChrW(160), "")
    s = Trim$(s)

    NormalizeHeaderText = LCase$(s)
End Function

Private Function FindHeaderColumn(ByVal ws As Worksheet, ByVal headerRow As Long, ByVal headerNames As Variant) As Long
    Dim lastCol As Long
    Dim col As Long
    Dim i As Long
    Dim cellHeader As String
    Dim targetHeader As String

    lastCol = ws.Cells(headerRow, ws.Columns.Count).End(xlToLeft).Column

    For col = 1 To lastCol
        cellHeader = NormalizeHeaderText(ws.Cells(headerRow, col).Value)
        If cellHeader <> "" Then
            For i = LBound(headerNames) To UBound(headerNames)
                targetHeader = NormalizeHeaderText(CStr(headerNames(i)))
                If cellHeader = targetHeader Then
                    FindHeaderColumn = col
                    Exit Function
                End If
            Next i
        End If
    Next col
End Function

Private Function GetMaxLastRow(ByVal ws As Worksheet, ParamArray cols() As Variant) As Long
    Dim i As Long
    Dim colNum As Long
    Dim lastRow As Long
    Dim maxRow As Long

    maxRow = 1

    For i = LBound(cols) To UBound(cols)
        colNum = CLng(cols(i))
        lastRow = ws.Cells(ws.Rows.Count, colNum).End(xlUp).Row
        If lastRow > maxRow Then maxRow = lastRow
    Next i

    GetMaxLastRow = maxRow
End Function

Private Function IsWholeBoxColumnSelected(ByVal sel As Range, ByVal boxCol As Long) As Boolean
    Dim area As Range

    IsWholeBoxColumnSelected = False
    If sel Is Nothing Then Exit Function

    For Each area In sel.Areas
        If area.Columns.Count = 1 Then
            If area.Column = boxCol And area.Rows.Count = Rows.Count Then
                IsWholeBoxColumnSelected = True
                Exit Function
            End If
        End If
    Next area
End Function

Private Function BoxExistsInArray(ByRef boxList() As String, ByVal boxCount As Long, ByVal boxNo As String) As Long
    Dim i As Long

    For i = 1 To boxCount
        If boxList(i) = boxNo Then
            BoxExistsInArray = i
            Exit Function
        End If
    Next i
End Function

Private Function PagesNeeded(ByVal itemCount As Long, ByVal rowsPerPage As Long) As Long
    If itemCount <= 0 Then
        PagesNeeded = 0
    Else
        PagesNeeded = (itemCount - 1) \ rowsPerPage + 1
    End If
End Function

Private Sub FormatLabelPage(ByVal ws As Worksheet, ByVal pageTop As Long, ByVal detailLastRow As Long)
    With ws.Range("A" & pageTop & ":C" & detailLastRow)
        .Font.Name = "Microsoft JhengHei"
        .VerticalAlignment = xlCenter
        .WrapText = False
        .Borders.LineStyle = xlContinuous
        .Borders.Weight = xlThin
    End With

    ws.Rows(pageTop).RowHeight = 24
    ws.Rows(pageTop + 1).RowHeight = 24
    ws.Rows(pageTop + 2).RowHeight = 22.1

    With ws.Range("A" & pageTop & ":B" & pageTop)
        .Merge
        .Font.Bold = True
        .Font.Size = 16
        .HorizontalAlignment = xlCenter
    End With

    With ws.Range("C" & pageTop)
        .Font.Bold = True
        .Font.Size = 12
        .HorizontalAlignment = xlCenter
    End With

    With ws.Range("A" & (pageTop + 1) & ":B" & (pageTop + 1))
        .Merge
        .Font.Bold = True
        .Font.Size = 16
        .HorizontalAlignment = xlCenter
    End With

    With ws.Range("C" & (pageTop + 1))
        .Font.Bold = False
        .Font.Size = 8
        .HorizontalAlignment = xlCenter
    End With

    With ws.Range("A" & (pageTop + 2) & ":C" & (pageTop + 2))
        .Font.Bold = True
        .Font.Size = 13
        .HorizontalAlignment = xlCenter
    End With

    ws.Range("A" & (pageTop + 2)).HorizontalAlignment = xlLeft
    ws.Range("B" & (pageTop + 2)).HorizontalAlignment = xlLeft

    If detailLastRow >= pageTop + 3 Then
        With ws.Range("A" & (pageTop + 3) & ":A" & detailLastRow)
            .Font.Bold = False
            .Font.Size = 12
            .HorizontalAlignment = xlLeft
        End With

        With ws.Range("B" & (pageTop + 3) & ":B" & detailLastRow)
            .Font.Bold = False
            .Font.Size = 12
            .HorizontalAlignment = xlLeft
        End With

        With ws.Range("C" & (pageTop + 3) & ":C" & detailLastRow)
            .Font.Bold = False
            .Font.Size = 12
            .HorizontalAlignment = xlCenter
        End With
    End If
End Sub

Public Sub PrintSelectedBoxLabelsPreview()
    Const HEADER_ROW As Long = 1
    Const ROWS_PER_PAGE As Long = 14
    Const PAGE_GAP As Long = 0

    Dim wb As Workbook
    Dim wsData As Worksheet
    Dim wsLabel As Worksheet

    Dim selectedBoxes As Collection
    Dim area As Range
    Dim cell As Range
    Dim c As Collection
    Dim sel As Range

    Dim lastDataRow As Long
    Dim rowNum As Long
    Dim pageIndex As Long
    Dim boxPageNo As Long
    Dim boxTotalPages As Long
    Dim pageTop As Long
    Dim lineRow As Long
    Dim totalLastRow As Long
    Dim lineCount As Long
    Dim detailLastRow As Long

    Dim i As Long
    Dim j As Long
    Dim boxIdx As Long

    Dim boxNo As String
    Dim skuText As String
    Dim qtyText As String
    Dim shelfText As String
    Dim missingHeaders As String

    Dim skuCol As Long
    Dim qtyCol As Long
    Dim boxCol As Long
    Dim shelfCol As Long

    Dim boxList() As String
    Dim lineTexts() As Collection
    Dim boxCount As Long
    Dim boxTotalQty() As Long

    Dim qtyVal As Variant
    Dim qtyNum As Double
    Dim skuVal As String
    Dim shelfVal As String

    Set wb = ActiveWorkbook
    Set wsData = ActiveSheet

    skuCol = FindHeaderColumn(wsData, HEADER_ROW, Array("SKU编号"))
    qtyCol = FindHeaderColumn(wsData, HEADER_ROW, Array("实发数量"))
    boxCol = FindHeaderColumn(wsData, HEADER_ROW, Array("箱號", "箱号"))
    shelfCol = FindHeaderColumn(wsData, HEADER_ROW, Array("台湾货架位"))

    If skuCol = 0 Then missingHeaders = missingHeaders & vbCrLf & "- SKU编号"
    If qtyCol = 0 Then missingHeaders = missingHeaders & vbCrLf & "- 实发数量"
    If boxCol = 0 Then missingHeaders = missingHeaders & vbCrLf & "- 箱號 / 箱号"
    If shelfCol = 0 Then missingHeaders = missingHeaders & vbCrLf & "- 台湾货架位"

    If missingHeaders <> "" Then
        MsgBox "Required headers were not found on the active sheet:" & vbCrLf & missingHeaders, vbExclamation
        Exit Sub
    End If

    If TypeName(Selection) <> "Range" Then
        MsgBox "Please select cells in the 箱號 / 箱号 column.", vbExclamation
        Exit Sub
    End If

    Set sel = Selection

    On Error Resume Next
    Set wsLabel = wb.Worksheets("PrintPreview")
    On Error GoTo 0

    If wsLabel Is Nothing Then
        Set wsLabel = wb.Worksheets.Add(After:=wb.Worksheets(wb.Worksheets.Count))
        wsLabel.Name = "PrintPreview"
    End If

    Set selectedBoxes = New Collection
    lastDataRow = GetMaxLastRow(wsData, skuCol, qtyCol, boxCol, shelfCol)

    If IsWholeBoxColumnSelected(sel, boxCol) Then
        For rowNum = HEADER_ROW + 1 To lastDataRow
            boxNo = NormalizeBoxNo(wsData.Cells(rowNum, boxCol).Value)
            If boxNo <> "" Then AddUniqueBox selectedBoxes, boxNo
        Next rowNum
    Else
        For Each area In sel.Areas
            For Each cell In area.Cells
                rowNum = cell.Row
                If rowNum >= HEADER_ROW + 1 And rowNum <= lastDataRow Then
                    If cell.Column = boxCol Then
                        boxNo = NormalizeBoxNo(wsData.Cells(rowNum, boxCol).Value)
                        If boxNo <> "" Then AddUniqueBox selectedBoxes, boxNo
                    End If
                End If
            Next cell
        Next area
    End If

    If selectedBoxes.Count = 0 Then
        MsgBox "No valid non-empty 箱號 / 箱号 were found in your selection.", vbExclamation
        Exit Sub
    End If

    If IsWholeBoxColumnSelected(sel, boxCol) Then
        For rowNum = HEADER_ROW + 1 To lastDataRow
            boxNo = NormalizeBoxNo(wsData.Cells(rowNum, boxCol).Value)
            If boxNo <> "" Then
                skuVal = Trim$(CStr(wsData.Cells(rowNum, skuCol).Value))
                qtyVal = wsData.Cells(rowNum, qtyCol).Value
                shelfVal = Trim$(CStr(wsData.Cells(rowNum, shelfCol).Value))

                If skuVal = "" Then
                    MsgBox "SKU编号 为空（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                    Exit Sub
                End If
                If Trim$(CStr(qtyVal)) = "" Then
                    MsgBox "实发数量 为空（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                    Exit Sub
                End If
                If Not IsNumeric(qtyVal) Then
                    MsgBox "实发数量 非数字（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                    Exit Sub
                End If

                qtyNum = CDbl(qtyVal)

                If qtyNum <= 0 Then
                    MsgBox "实发数量 <= 0（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                    Exit Sub
                End If
                If qtyNum <> Int(qtyNum) Then
                    MsgBox "实发数量 不是整数（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                    Exit Sub
                End If
                If shelfVal = "" Then
                    MsgBox "台湾货架位 为空（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                    Exit Sub
                End If
            End If
        Next rowNum
    Else
        For Each area In sel.Areas
            For Each cell In area.Cells
                rowNum = cell.Row
                If rowNum >= HEADER_ROW + 1 And rowNum <= lastDataRow Then
                    If cell.Column = boxCol Then
                        boxNo = NormalizeBoxNo(wsData.Cells(rowNum, boxCol).Value)
                        If boxNo <> "" Then
                            skuVal = Trim$(CStr(wsData.Cells(rowNum, skuCol).Value))
                            qtyVal = wsData.Cells(rowNum, qtyCol).Value
                            shelfVal = Trim$(CStr(wsData.Cells(rowNum, shelfCol).Value))

                            If skuVal = "" Then
                                MsgBox "SKU编号 为空（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                                Exit Sub
                            End If
                            If Trim$(CStr(qtyVal)) = "" Then
                                MsgBox "实发数量 为空（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                                Exit Sub
                            End If
                            If Not IsNumeric(qtyVal) Then
                                MsgBox "实发数量 非数字（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                                Exit Sub
                            End If

                            qtyNum = CDbl(qtyVal)

                            If qtyNum <= 0 Then
                                MsgBox "实发数量 <= 0（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                                Exit Sub
                            End If
                            If qtyNum <> Int(qtyNum) Then
                                MsgBox "实发数量 不是整数（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                                Exit Sub
                            End If
                            If shelfVal = "" Then
                                MsgBox "台湾货架位 为空（行 " & rowNum & "，箱号 " & boxNo & "）。请修正后再打印。", vbExclamation
                                Exit Sub
                            End If
                        End If
                    End If
                End If
            Next cell
        Next area
    End If

    ReDim boxList(1 To selectedBoxes.Count)
    ReDim lineTexts(1 To selectedBoxes.Count)
    ReDim boxTotalQty(1 To selectedBoxes.Count)

    For i = 1 To selectedBoxes.Count
        boxList(i) = CStr(selectedBoxes(i))
        Set lineTexts(i) = New Collection
        boxTotalQty(i) = 0
    Next i

    boxCount = selectedBoxes.Count

    For rowNum = HEADER_ROW + 1 To lastDataRow
        boxNo = NormalizeBoxNo(wsData.Cells(rowNum, boxCol).Value)
        If boxNo <> "" Then
            boxIdx = BoxExistsInArray(boxList, boxCount, boxNo)
            If boxIdx > 0 Then
                skuText = Trim$(CStr(wsData.Cells(rowNum, skuCol).Value))
                qtyText = Trim$(CStr(wsData.Cells(rowNum, qtyCol).Value))
                shelfText = Trim$(CStr(wsData.Cells(rowNum, shelfCol).Value))

                If skuText <> "" And qtyText <> "" And shelfText <> "" Then
                    If IsNumeric(qtyText) Then
                        If CDbl(qtyText) > 0 And CDbl(qtyText) = Int(CDbl(qtyText)) Then
                            lineTexts(boxIdx).Add Array(skuText, qtyText, shelfText)
                            boxTotalQty(boxIdx) = boxTotalQty(boxIdx) + CLng(CDbl(qtyText))
                        End If
                    End If
                End If
            End If
        End If
    Next rowNum

    Application.ScreenUpdating = False

    wsLabel.Cells.Clear
    wsLabel.ResetAllPageBreaks

    wsLabel.Columns("A").ColumnWidth = 11.5
    wsLabel.Columns("B").ColumnWidth = 35.5
    wsLabel.Columns("C").ColumnWidth = 7.6

    With wsLabel.PageSetup
        On Error Resume Next
        .Zoom = False
        .FitToPagesWide = 1
        .FitToPagesTall = False
        .Orientation = xlPortrait
        .CenterHorizontally = True
        .CenterVertically = False
        .LeftMargin = Application.CentimetersToPoints(0.3)
        .RightMargin = Application.CentimetersToPoints(0.3)
        .TopMargin = Application.CentimetersToPoints(0.3)
        .BottomMargin = Application.CentimetersToPoints(0.3)
        .HeaderMargin = 0
        .FooterMargin = 0
        On Error GoTo 0
    End With

    pageIndex = 0
    totalLastRow = 1

    For i = 1 To boxCount
        Set c = lineTexts(i)
        If c.Count > 0 Then
            j = 1
            boxPageNo = 0
            boxTotalPages = PagesNeeded(c.Count, ROWS_PER_PAGE)

            Do While j <= c.Count
                pageIndex = pageIndex + 1
                boxPageNo = boxPageNo + 1

                If pageIndex = 1 Then
                    pageTop = 1
                Else
                    pageTop = totalLastRow + PAGE_GAP + 1
                    wsLabel.HPageBreaks.Add Before:=wsLabel.Rows(pageTop)
                End If

                wsLabel.Range("A" & pageTop & ":B" & pageTop).UnMerge
                wsLabel.Range("A" & (pageTop + 1) & ":B" & (pageTop + 1)).UnMerge

                wsLabel.Range("A" & pageTop).Value = BoxLabel_Text_Title()
                wsLabel.Range("C" & pageTop).Value = BoxLabel_Text_BoxNo() & " " & boxList(i)

                wsLabel.Range("A" & (pageTop + 1)).Value = _
                    BoxLabel_Text_SKUCount() & " " & c.Count & "  |  " & _
                    BoxLabel_Text_TotalQty() & boxTotalQty(i)
                wsLabel.Range("C" & (pageTop + 1)).Value = BoxLabel_Text_PageInfo(boxPageNo, boxTotalPages)

                wsLabel.Range("A" & (pageTop + 2)).Value = BoxLabel_Text_DetailHeader_Right()
                wsLabel.Range("B" & (pageTop + 2)).Value = BoxLabel_Text_DetailHeader_Left()
                wsLabel.Range("C" & (pageTop + 2)).Value = BoxLabel_Text_QtyHeader()

                lineRow = pageTop + 3
                lineCount = 0

                Do While j <= c.Count And lineCount < ROWS_PER_PAGE
                    wsLabel.Range("A" & lineRow).Value = CStr(c(j)(2))
                    wsLabel.Range("B" & lineRow).Value = CStr(c(j)(0))
                    wsLabel.Range("C" & lineRow).Value = CStr(c(j)(1))
                    wsLabel.Rows(lineRow).RowHeight = 20.05
                    lineRow = lineRow + 1
                    lineCount = lineCount + 1
                    j = j + 1
                Loop

                detailLastRow = lineRow - 1
                FormatLabelPage wsLabel, pageTop, detailLastRow
                totalLastRow = detailLastRow
            Loop
        End If
    Next i

    If pageIndex = 0 Then
        Application.ScreenUpdating = True
        MsgBox "No valid packed rows were found for the selected 箱號 / 箱号.", vbExclamation
        Exit Sub
    End If

    wsLabel.PageSetup.PrintArea = wsLabel.Range("A1:C" & totalLastRow).Address

    Application.ScreenUpdating = True
    wsLabel.PrintPreview
End Sub
