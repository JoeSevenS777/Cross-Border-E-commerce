Option Explicit

' Taiwan Transfer Macro
' Place this code in a standard module inside Inventory List.xlsm

Private Const BIGSELLER_PREFIX As String = "Bigseller调拨导入"
Private Const BIGSELLER_EXT As String = ".xlsx"
Private Const TAIWAN_PREFIX As String = "台湾仓库调拨表"
Private Const TAIWAN_EXT As String = ".xlsm"
Private Const ONEDRIVE_FOLDER As String = "C:\Users\zouzh\OneDrive\"
Private Const TAIWAN_LOG_FOLDER As String = "D:\JoeProgramFiles\inventory\Taiwan transfer logs\"
Private Const DEBUG_MODE As Boolean = False
Private Const TAIWAN_WORKING_HEADERS As String = "SKU编号|GTIN|预测日销量|台湾库存|调拨数量|台湾货架位"
Private Const BIGSELLER_WORKING_HEADERS As String = "*Provisional No.(Required)|*Shipping Warehouse(Required)|*Receiving Warehouse(Required)|*Merchant SKU(Required)|*Transfer Qty(Required)|Ship Fee|Tracking No.|Cost Allocation Method (Price/Quantity/Volume/Weight)|Estimated Arrival Date|Note"
Private Const BIGSELLER_SHEET_NAME As String = "SKU"

Private Type TransferRow
    SKU As String
    GTIN As String
    DailySales As Variant
    TotalStock As Variant
    QtyRaw As Variant
    QtyForBigseller As Variant
    Shelf As String
End Type

Public Sub CreateTaiwanTransferDocuments()
    Dim sourceSheetNames As Variant
    Dim transfers() As TransferRow
    Dim transferCount As Long
    Dim todayStamp As String
    Dim baseFolder As String
    Dim bigsellerOutputPath As String
    Dim taiwanCurrentPath As String
    Dim taiwanRenamedPath As String
    Dim taiwanLogCopyPath As String
    Dim successMessage As String
    Dim answer As VbMsgBoxResult
    
    On Error GoTo CleanFail
    SetAppState False
    TraceStep "Start macro"
    
    sourceSheetNames = Array("采菁", "萌睫", "Flortte", "魔仙", "夹子", "其他备货")
    todayStamp = Format(Date, "yyyymmdd")
    baseFolder = IncludeTrailingSlash(ThisWorkbook.Path)
    
    If Len(baseFolder) = 0 Then
        Err.Raise vbObjectError + 1000, , "Cannot determine the folder of """ & ThisWorkbook.Name & """."
    End If
    
    ValidateFolderExists baseFolder, "Base folder of """ & ThisWorkbook.Name & """"
    ValidateFolderExists ONEDRIVE_FOLDER, "OneDrive folder"
    ValidateFolderExists TAIWAN_LOG_FOLDER, "Taiwan transfer logs folder"
    
    transferCount = CollectTransferRows(ThisWorkbook, sourceSheetNames, transfers)
    If transferCount = 0 Then
        MsgBox "no transfer found", vbInformation
        GoTo CleanExit
    End If
    
    bigsellerOutputPath = baseFolder & BIGSELLER_PREFIX & todayStamp & BIGSELLER_EXT
    taiwanCurrentPath = EnsureTaiwanWorkingFile(IncludeTrailingSlash(ONEDRIVE_FOLDER), IncludeTrailingSlash(TAIWAN_LOG_FOLDER))
    taiwanLogCopyPath = GetAvailableFilePath(IncludeTrailingSlash(TAIWAN_LOG_FOLDER) & GetFileNameOnly(taiwanCurrentPath))
    
    TraceStep "Create Bigseller file"
    CreateFreshBigsellerFile bigsellerOutputPath, transfers, transferCount
    RecycleOldDatedFiles baseFolder, BIGSELLER_PREFIX, BIGSELLER_EXT, bigsellerOutputPath
    
    TraceStep "Archive and update Taiwan file"
    FileCopy taiwanCurrentPath, taiwanLogCopyPath
    BuildTaiwanTransferFile taiwanCurrentPath, transfers, transferCount
    taiwanRenamedPath = RenameTaiwanFileWithTimestamp(taiwanCurrentPath)
    
    successMessage = "Taiwan transfer documents created successfully." & vbCrLf & vbCrLf & _
                     "Bigseller file:" & vbCrLf & GetFileNameOnly(bigsellerOutputPath) & vbCrLf & vbCrLf & _
                     "Taiwan OneDrive file renamed to:" & vbCrLf & GetFileNameOnly(taiwanRenamedPath) & vbCrLf & vbCrLf & _
                     "Taiwan log copy created:" & vbCrLf & GetFileNameOnly(taiwanLogCopyPath) & vbCrLf & vbCrLf & _
                     "Open both files now?"
    
    answer = MsgBox(successMessage, vbQuestion + vbYesNo, "Taiwan Transfer Completed")
    If answer = vbYes Then
        OpenFileInExcel bigsellerOutputPath, "Bigseller output file"
        OpenFileInExcel taiwanRenamedPath, "Taiwan transfer file"
    End If
    
CleanExit:
    SetAppState True
    Exit Sub
    
CleanFail:
    SetAppState True
    MsgBox Err.Description, vbCritical, "Taiwan Transfer Macro"
End Sub

Private Function CollectTransferRows(ByVal wb As Workbook, ByVal sourceSheetNames As Variant, ByRef transfers() As TransferRow) As Long
    Dim ws As Worksheet
    Dim i As Long
    Dim lastRow As Long
    Dim rowIndex As Long
    Dim actionCol As Long, skuCol As Long, gtinCol As Long
    Dim dailySalesCol As Long, totalStockCol As Long, qtyCol As Long, shelfCol As Long
    Dim normalizedAction As String
    Dim count As Long
    
    For i = LBound(sourceSheetNames) To UBound(sourceSheetNames)
        Set ws = GetWorksheetByName(wb, CStr(sourceSheetNames(i)))
        If ws Is Nothing Then
            Err.Raise vbObjectError + 1100, , "Missing source sheet: " & CStr(sourceSheetNames(i)) & " in workbook " & wb.Name
        End If
        
        actionCol = GetHeaderColumnOrFail(ws, "action")
        skuCol = GetHeaderColumnOrFail(ws, "SKU")
        gtinCol = GetHeaderColumnOrFail(ws, "GTIN")
        dailySalesCol = GetHeaderColumnOrFail(ws, "Daily Sales")
        totalStockCol = GetHeaderColumnOrFail(ws, "Total Stock")
        qtyCol = GetHeaderColumnOrFail(ws, "数量")
        shelfCol = GetHeaderColumnOrFail(ws, "shelf")
        
        lastRow = GetLastUsedRow(ws)
        If lastRow < 2 Then GoTo NextSheet
        
        For rowIndex = 2 To lastRow
            If Not ws.Rows(rowIndex).Hidden Then
                normalizedAction = NormalizeValue(ws.Cells(rowIndex, actionCol).Value)
                If normalizedAction = "transfer" Then
                    count = count + 1
                    ReDim Preserve transfers(1 To count)
                    
                    transfers(count).SKU = Trim$(CStr(ws.Cells(rowIndex, skuCol).Value))
                    transfers(count).GTIN = Trim$(CStr(ws.Cells(rowIndex, gtinCol).Value))
                    transfers(count).DailySales = ws.Cells(rowIndex, dailySalesCol).Value
                    transfers(count).TotalStock = ws.Cells(rowIndex, totalStockCol).Value
                    transfers(count).QtyRaw = ws.Cells(rowIndex, qtyCol).Value
                    transfers(count).QtyForBigseller = NormalizeQtyForBigseller(ws.Cells(rowIndex, qtyCol).Value)
                    transfers(count).Shelf = Trim$(CStr(ws.Cells(rowIndex, shelfCol).Value))
                End If
            End If
        Next rowIndex
        
NextSheet:
    Next i
    
    CollectTransferRows = count
End Function

Private Sub CreateFreshBigsellerFile(ByVal filePath As String, ByRef transfers() As TransferRow, ByVal transferCount As Long)
    RecycleIfExists filePath
    CreateBlankBigsellerWorkbook filePath
    BuildBigsellerFile filePath, transfers, transferCount
End Sub

Private Sub BuildBigsellerFile(ByVal filePath As String, ByRef transfers() As TransferRow, ByVal transferCount As Long)
    Dim wb As Workbook
    Dim ws As Worksheet
    Dim colProvisional As Long, colShipping As Long, colReceiving As Long
    Dim colSKU As Long, colQty As Long
    Dim rowIndex As Long
    
    Set wb = Workbooks.Open(Filename:=filePath, UpdateLinks:=False, ReadOnly:=False)
    On Error GoTo BigsellerFail
    Set ws = wb.Worksheets(1)
    
    colProvisional = GetHeaderColumnOrFail(ws, "*Provisional No.(Required)")
    colShipping = GetHeaderColumnOrFail(ws, "*Shipping Warehouse(Required)")
    colReceiving = GetHeaderColumnOrFail(ws, "*Receiving Warehouse(Required)")
    colSKU = GetHeaderColumnOrFail(ws, "*Merchant SKU(Required)")
    colQty = GetHeaderColumnOrFail(ws, "*Transfer Qty(Required)")
    
    ClearDataRows ws
    
    For rowIndex = 1 To transferCount
        ws.Cells(rowIndex + 1, colProvisional).Value = 1
        ws.Cells(rowIndex + 1, colShipping).Value = "default warehouse"
        ws.Cells(rowIndex + 1, colReceiving).Value = "Taiwan"
        ws.Cells(rowIndex + 1, colSKU).Value = transfers(rowIndex).SKU
        ws.Cells(rowIndex + 1, colQty).Value = transfers(rowIndex).QtyForBigseller
    Next rowIndex
    
    wb.Save
    wb.Close SaveChanges:=False
    Exit Sub
    
BigsellerFail:
    On Error Resume Next
    If Not wb Is Nothing Then wb.Close SaveChanges:=False
    On Error GoTo 0
    Err.Raise Err.Number, , Err.Description
End Sub

Private Sub BuildTaiwanTransferFile(ByVal filePath As String, ByRef transfers() As TransferRow, ByVal transferCount As Long)
    Dim wb As Workbook
    Dim ws As Worksheet
    Dim colSKU As Long, colGTIN As Long, colDailySales As Long
    Dim colTaiwanStock As Long, colQty As Long, colShelf As Long
    Dim rowIndex As Long
    
    Set wb = Workbooks.Open(Filename:=filePath, UpdateLinks:=False, ReadOnly:=False)
    On Error GoTo TaiwanFail
    Set ws = wb.Worksheets(1)
    
    colSKU = GetHeaderColumnOrFail(ws, "SKU编号")
    colGTIN = GetHeaderColumnOrFail(ws, "GTIN")
    colDailySales = GetHeaderColumnOrFail(ws, "预测日销量")
    colTaiwanStock = GetHeaderColumnOrFail(ws, "台湾库存")
    colQty = GetHeaderColumnOrFail(ws, "调拨数量")
    colShelf = GetHeaderColumnOrFail(ws, "台湾货架位")
    
    ClearDataRows ws
    
    For rowIndex = 1 To transferCount
        ws.Cells(rowIndex + 1, colSKU).Value = transfers(rowIndex).SKU
        ws.Cells(rowIndex + 1, colGTIN).Value = transfers(rowIndex).GTIN
        ws.Cells(rowIndex + 1, colDailySales).Value = transfers(rowIndex).DailySales
        ws.Cells(rowIndex + 1, colTaiwanStock).Value = transfers(rowIndex).TotalStock
        ws.Cells(rowIndex + 1, colQty).Value = transfers(rowIndex).QtyRaw
        ws.Cells(rowIndex + 1, colShelf).Value = transfers(rowIndex).Shelf
    Next rowIndex
    
    wb.Save
    wb.Close SaveChanges:=False
    Exit Sub
    
TaiwanFail:
    On Error Resume Next
    If Not wb Is Nothing Then wb.Close SaveChanges:=False
    On Error GoTo 0
    Err.Raise Err.Number, , Err.Description
End Sub

Private Function GetHeaderColumnOrFail(ByVal ws As Worksheet, ByVal expectedHeader As String) As Long
    Dim col As Long
    Dim lastCol As Long
    Dim cellText As String
    Dim targetHeader As String
    
    targetHeader = NormalizeHeader(expectedHeader)
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    
    For col = 1 To lastCol
        cellText = NormalizeHeader(CStr(ws.Cells(1, col).Value))
        If cellText = targetHeader Then
            GetHeaderColumnOrFail = col
            Exit Function
        End If
    Next col
    
    Err.Raise vbObjectError + 1200, , "Missing header """ & expectedHeader & """ in sheet """ & ws.Name & """ of workbook """ & ws.Parent.Name & """."
End Function

Private Function NormalizeHeader(ByVal value As String) As String
    Dim s As String
    s = LCase$(CStr(value))
    s = Replace(s, vbCr, vbNullString)
    s = Replace(s, vbLf, vbNullString)
    s = Replace(s, vbTab, vbNullString)
    s = Replace(s, Chr$(160), vbNullString)
    s = Replace(s, " ", vbNullString)
    NormalizeHeader = Trim$(s)
End Function

Private Function NormalizeValue(ByVal value As Variant) As String
    Dim s As String
    s = LCase$(Trim$(CStr(value)))
    s = Replace(s, vbCr, vbNullString)
    s = Replace(s, vbLf, vbNullString)
    NormalizeValue = s
End Function

Private Function NormalizeQtyForBigseller(ByVal value As Variant) As Variant
    If IsError(value) Then
        NormalizeQtyForBigseller = vbNullString
    ElseIf Len(Trim$(CStr(value))) = 0 Then
        NormalizeQtyForBigseller = vbNullString
    ElseIf IsNumeric(value) Then
        NormalizeQtyForBigseller = CDbl(value)
    Else
        NormalizeQtyForBigseller = vbNullString
    End If
End Function

Private Sub ClearDataRows(ByVal ws As Worksheet)
    Dim lastRow As Long
    Dim lastCol As Long
    
    lastRow = GetLastUsedRow(ws)
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    
    If lastRow >= 2 And lastCol >= 1 Then
        ws.Range(ws.Cells(2, 1), ws.Cells(lastRow, lastCol)).ClearContents
    End If
End Sub

Private Function GetLastUsedRow(ByVal ws As Worksheet) As Long
    Dim lastCell As Range
    On Error Resume Next
    Set lastCell = ws.Cells.Find(What:="*", After:=ws.Cells(1, 1), LookIn:=xlFormulas, _
                                 LookAt:=xlPart, SearchOrder:=xlByRows, SearchDirection:=xlPrevious, MatchCase:=False)
    On Error GoTo 0
    
    If lastCell Is Nothing Then
        GetLastUsedRow = 1
    Else
        GetLastUsedRow = lastCell.Row
    End If
End Function

Private Function GetLatestDatedFile(ByVal folderPath As String, ByVal prefix As String, ByVal extensionWithDot As String) As String
    Dim fileName As String
    Dim bestPath As String
    Dim bestDateText As String
    Dim currentDateText As String
    
    fileName = Dir$(folderPath & prefix & "*" & extensionWithDot, vbNormal)
    Do While Len(fileName) > 0
        currentDateText = ExtractDateStampFromName(fileName, prefix, extensionWithDot)
        If Len(currentDateText) > 0 Then
            If Len(bestDateText) = 0 Or currentDateText > bestDateText Then
                bestDateText = currentDateText
                bestPath = folderPath & fileName
            End If
        End If
        fileName = Dir$
    Loop
    
    GetLatestDatedFile = bestPath
End Function

Private Function EnsureTaiwanWorkingFile(ByVal oneDriveFolder As String, ByVal logFolder As String) As String
    Dim currentPath As String
    Dim sourceTemplatePath As String
    Dim newPath As String
    
    currentPath = GetLatestDatedFile(oneDriveFolder, TAIWAN_PREFIX, TAIWAN_EXT)
    If Len(currentPath) > 0 Then
        EnsureTaiwanWorkingFile = currentPath
        Exit Function
    End If
    
    TraceStep "Taiwan working file not found in OneDrive. Creating one."
    sourceTemplatePath = GetLatestDatedFile(logFolder, TAIWAN_PREFIX, TAIWAN_EXT)
    newPath = BuildTaiwanTimestampPath(oneDriveFolder)
    
    If Len(sourceTemplatePath) > 0 Then
        FileCopy sourceTemplatePath, newPath
    Else
        CreateBlankTaiwanWorkbook newPath
    End If
    
    If Not FileExists(newPath) Then
        Err.Raise vbObjectError + 1002, , "Failed to create Taiwan working file in: " & oneDriveFolder
    End If
    
    EnsureTaiwanWorkingFile = newPath
End Function

Private Function ExtractDateStampFromName(ByVal fileName As String, ByVal prefix As String, ByVal extensionWithDot As String) As String
    Dim coreName As String
    coreName = fileName
    
    If LCase$(Left$(coreName, Len(prefix))) <> LCase$(prefix) Then Exit Function
    If LCase$(Right$(coreName, Len(extensionWithDot))) <> LCase$(extensionWithDot) Then Exit Function
    
    coreName = Mid$(coreName, Len(prefix) + 1)
    coreName = Left$(coreName, Len(coreName) - Len(extensionWithDot))
    coreName = Trim$(coreName)
    
    If Len(coreName) >= 8 And Len(coreName) <= 14 And IsAllDigits(coreName) Then
        ExtractDateStampFromName = coreName
    End If
End Function

Private Sub RecycleOldDatedFiles(ByVal folderPath As String, ByVal prefix As String, ByVal extensionWithDot As String, ByVal excludeFullPath As String)
    Dim fileName As String
    Dim fullPath As String
    Dim pathsToRecycle As Collection
    Dim item As Variant
    
    Set pathsToRecycle = New Collection
    fileName = Dir$(folderPath & prefix & "*" & extensionWithDot, vbNormal)
    
    Do While Len(fileName) > 0
        fullPath = folderPath & fileName
        If StrComp(fullPath, excludeFullPath, vbTextCompare) <> 0 Then
            If Len(ExtractDateStampFromName(fileName, prefix, extensionWithDot)) > 0 Then
                pathsToRecycle.Add fullPath
            End If
        End If
        fileName = Dir$
    Loop
    
    For Each item In pathsToRecycle
        RecycleFile CStr(item)
    Next item
End Sub

Private Function BuildTaiwanTimestampPath(ByVal folderPath As String) As String
    Dim stamp As String
    stamp = Format(Now, "yyyymmddhhnnss")
    BuildTaiwanTimestampPath = IncludeTrailingSlash(folderPath) & TAIWAN_PREFIX & stamp & TAIWAN_EXT
End Function

Private Sub CreateBlankTaiwanWorkbook(ByVal filePath As String)
    CreateWorkbookWithHeaders filePath, Split(TAIWAN_WORKING_HEADERS, "|"), xlOpenXMLWorkbookMacroEnabled, vbNullString
End Sub

Private Sub CreateBlankBigsellerWorkbook(ByVal filePath As String)
    CreateWorkbookWithHeaders filePath, Split(BIGSELLER_WORKING_HEADERS, "|"), xlOpenXMLWorkbook, BIGSELLER_SHEET_NAME
End Sub

Private Sub CreateWorkbookWithHeaders(ByVal filePath As String, ByVal headers As Variant, ByVal fileFormat As XlFileFormat, Optional ByVal sheetName As String = vbNullString)
    Dim wb As Workbook
    Dim ws As Worksheet
    Dim i As Long
    
    Set wb = Workbooks.Add(xlWBATWorksheet)
    Set ws = wb.Worksheets(1)
    
    If Len(sheetName) > 0 Then
        On Error Resume Next
        ws.Name = sheetName
        On Error GoTo 0
    End If
    
    For i = LBound(headers) To UBound(headers)
        ws.Cells(1, i + 1).Value = headers(i)
    Next i
    
    Application.DisplayAlerts = False
    wb.SaveAs Filename:=filePath, FileFormat:=fileFormat
    Application.DisplayAlerts = True
    wb.Close SaveChanges:=False
End Sub

Private Function RenameTaiwanFileWithTimestamp(ByVal sourcePath As String) As String
    Dim folderPath As String
    Dim baseTargetPath As String
    Dim targetPath As String
    Dim counter As Long
    
    folderPath = Left$(sourcePath, InStrRev(sourcePath, "\"))
    baseTargetPath = BuildTaiwanTimestampPath(folderPath)
    targetPath = baseTargetPath
    
    counter = 1
    Do While FileExists(targetPath)
        targetPath = Left$(baseTargetPath, Len(baseTargetPath) - Len(TAIWAN_EXT)) & "_" & CStr(counter) & TAIWAN_EXT
        counter = counter + 1
    Loop
    
    EnsureWorkbookClosed sourcePath
    Name sourcePath As targetPath
    
    If Not FileExists(targetPath) Then
        Err.Raise vbObjectError + 1600, , "Failed to rename Taiwan OneDrive file to: " & targetPath
    End If
    
    RenameTaiwanFileWithTimestamp = targetPath
End Function

Private Function GetAvailableFilePath(ByVal preferredPath As String) As String
    Dim folderPath As String
    Dim baseName As String
    Dim extensionWithDot As String
    Dim candidatePath As String
    Dim n As Long
    
    If Not FileExists(preferredPath) Then
        GetAvailableFilePath = preferredPath
        Exit Function
    End If
    
    folderPath = Left$(preferredPath, InStrRev(preferredPath, "\"))
    baseName = Mid$(preferredPath, InStrRev(preferredPath, "\") + 1)
    extensionWithDot = Mid$(baseName, InStrRev(baseName, "."))
    baseName = Left$(baseName, Len(baseName) - Len(extensionWithDot))
    
    n = 1
    Do
        candidatePath = folderPath & baseName & "_" & Format(Now, "yyyymmdd_hhnnss") & "_" & CStr(n) & extensionWithDot
        If Not FileExists(candidatePath) Then
            GetAvailableFilePath = candidatePath
            Exit Do
        End If
        n = n + 1
    Loop
End Function

Private Function IsAllDigits(ByVal textValue As String) As Boolean
    Dim i As Long
    If Len(textValue) = 0 Then Exit Function
    For i = 1 To Len(textValue)
        If Mid$(textValue, i, 1) < "0" Or Mid$(textValue, i, 1) > "9" Then Exit Function
    Next i
    IsAllDigits = True
End Function

Private Function FileExists(ByVal filePath As String) As Boolean
    FileExists = (Len(Dir$(filePath, vbNormal Or vbReadOnly Or vbHidden Or vbSystem)) > 0)
End Function

Private Sub RecycleIfExists(ByVal filePath As String)
    If FileExists(filePath) Then
        EnsureWorkbookClosed filePath
        RecycleFile filePath
    End If
End Sub

Private Sub RecycleFile(ByVal filePath As String)
    Dim cmd As String
    
    If Not FileExists(filePath) Then Exit Sub
    EnsureWorkbookClosed filePath
    
    cmd = "powershell -NoProfile -ExecutionPolicy Bypass -Command " & _
          Chr(34) & _
          "$path = [IO.Path]::GetFullPath('" & Replace(filePath, "'", "''") & "'); " & _
          "Add-Type -AssemblyName Microsoft.VisualBasic; " & _
          "[Microsoft.VisualBasic.FileIO.FileSystem]::DeleteFile($path,'OnlyErrorDialogs','SendToRecycleBin')" & _
          Chr(34)
    
    Shell cmd, vbHide
    WaitForFileGone filePath, 5
    
    If FileExists(filePath) Then
        Err.Raise vbObjectError + 1300, , "Failed to move file to Recycle Bin: " & filePath & vbCrLf & "The file may still be open or locked."
    End If
End Sub

Private Sub ValidateFolderExists(ByVal folderPath As String, ByVal folderLabel As String)
    Dim normalizedPath As String
    normalizedPath = IncludeTrailingSlash(folderPath)
    If Dir$(normalizedPath, vbDirectory) = vbNullString Then
        Err.Raise vbObjectError + 1400, , folderLabel & " does not exist: " & normalizedPath
    End If
End Sub

Private Function GetWorksheetByName(ByVal wb As Workbook, ByVal sheetName As String) As Worksheet
    On Error Resume Next
    Set GetWorksheetByName = wb.Worksheets(sheetName)
    On Error GoTo 0
End Function

Private Function IncludeTrailingSlash(ByVal folderPath As String) As String
    If Right$(folderPath, 1) = "\" Then
        IncludeTrailingSlash = folderPath
    Else
        IncludeTrailingSlash = folderPath & "\"
    End If
End Function

Private Function GetFileNameOnly(ByVal fullPath As String) As String
    GetFileNameOnly = Mid$(fullPath, InStrRev(fullPath, "\") + 1)
End Function

Private Sub OpenFileInExcel(ByVal filePath As String, Optional ByVal fileLabel As String = "Output file")
    If FileExists(filePath) Then
        Workbooks.Open Filename:=filePath, UpdateLinks:=False, ReadOnly:=False
    Else
        MsgBox fileLabel & " was not found or could not be opened:" & vbCrLf & vbCrLf & filePath, vbExclamation, "Open Output File"
    End If
End Sub

Private Sub EnsureWorkbookClosed(ByVal filePath As String)
    Dim wb As Workbook
    Dim targetPath As String
    
    targetPath = LCase$(filePath)
    For Each wb In Application.Workbooks
        If LCase$(wb.FullName) = targetPath Then
            wb.Close SaveChanges:=False
            Exit For
        End If
    Next wb
End Sub

Private Sub SetAppState(ByVal restoreState As Boolean)
    If restoreState Then
        Application.StatusBar = False
        Application.ScreenUpdating = True
        Application.EnableEvents = True
        Application.DisplayAlerts = True
    Else
        Application.ScreenUpdating = False
        Application.EnableEvents = False
        Application.DisplayAlerts = False
        Application.StatusBar = "Preparing Taiwan transfer files..."
    End If
End Sub

Private Sub TraceStep(ByVal msg As String)
    If DEBUG_MODE Then Debug.Print Format(Now, "hh:nn:ss"), msg
    Application.StatusBar = msg
End Sub

Private Sub WaitForFileGone(ByVal filePath As String, ByVal timeoutSeconds As Long)
    Dim started As Single
    started = Timer
    
    Do While FileExists(filePath)
        DoEvents
        Application.Wait Now + TimeSerial(0, 0, 1)
        If Timer - started >= timeoutSeconds Then Exit Do
    Loop
End Sub
